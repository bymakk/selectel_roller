# Скопируйте в .env в корне проекта (файл .env не коммитится).
# load_dotenv подхватывает .env при старте; непустое значение здесь перекрывает
# значения по умолчанию из аргументов CLI (если переменная задана).

# --- Первый проект Selectel (config.json → selectel.api) ---
SEL_USERNAME=
SEL_PASSWORD=
SEL_ACCOUNT_ID=
SEL_PROJECT_NAME=
SEL_PROJECT_ID=
SEL_SERVER_ID_RU2=
SEL_SERVER_ID_RU3=

# --- Второй проект (additional_accounts[0]) ---
# Опционально: если заданы только SEL_* — запустится один воркер; если заданы SEL2_* или блок
# additional_accounts — второй. Неполный набор у одного воркера не блокирует другой: в dual
# воркер без данных не стартует, причина — в Recent Events под этим аккаунтом.
SEL2_USERNAME=
SEL2_PASSWORD=
SEL2_ACCOUNT_ID=
SEL2_PROJECT_NAME=
SEL2_PROJECT_ID=
SEL2_SERVER_ID_RU2=
SEL2_SERVER_ID_RU3=
# Альтернатива: список UUID через запятую (если задано — попадает в server_ids в config)
# SEL2_SERVER_IDS=

# --- Регионы (опционально) ---
# Список через запятую, напр. ru-1,ru-2,ru-3. Пусто — из config / каталога API.
# SEL_SCANNER_REGIONS=
#
# Dual (два воркера в одном процессе): отдельные зоны на 1-й и 2-й аккаунт.
# Неизвестные имена отбрасываются; пусто — все доступные регионы для этого аккаунта.
# CLI --regions по-прежнему задаёт один и тот же список обоим воркерам.
# SEL1_SCANNER_REGIONS=
# SEL2_SCANNER_REGIONS=

# ========== Скорость перебора IP и тайминги (на один процесс; лимит — на аккаунт) ==========
#
# --- Ориентир: ~30 floating IP/мин на каждый воркер ---
# В dual два аккаунта → два независимых скользящих окна: SEL_MAX_IPS_PER_MINUTE=30 даёт 30/мин на 1-го и 30/мин на 2-го.
# Средний интервал между выдачами: ≥ 2 с (60÷30). Рекомендуется батч 1/1, чтобы не делать скачков выше лимита.
# DELETE: 6–8; при 429 — меньше. Cooldown 1.2/15 — типично; reconcile 7–15 с (реже GET в фоне). Poll 5×0.45 с при батче 1.
#
# Главный рычаг: сколько floating IP выдать за скользящие 60 с на аккаунт. 0 = без лимита.
# SEL_MAX_IPS_PER_MINUTE=30

# Сколько целевых совпадений по whitelist искать (остановка после достижения).
# SEL_TARGET_COUNT=1

# Размер батча: при 30/мин обычно 1 и 1.
# SEL_BATCH_SIZE=1
# SEL_MAX_BATCH_SIZE=1

# Параллельные DELETE несовпавших IP (реком. 6–8; не раздувать при лимитах API).
# SEL_DELETE_CONCURRENCY=8

# Пауза стратегии при пустом ответе и backoff (сек); реком. 1.2 / 15.
# SEL_COOLDOWN_BASE=1.2
# SEL_COOLDOWN_MAX=15

# Фоновая сверка «лишних» floating IP (сек); реком. 7–15.
# SEL_RECONCILE_INTERVAL=7

# После create: опрос списка floating IP (реком. 5 и 0.45 с).
# SEL_ALLOCATION_POLL_ATTEMPTS=5
# SEL_ALLOCATION_POLL_DELAY=0.45

# Частота обновления Rich (Гц); только UI, реком. 5–8.
# SEL_REFRESH_PER_SECOND=6
