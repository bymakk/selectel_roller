# Скопируйте в .env в корне проекта (файл .env не коммитится).
# load_dotenv подхватывает .env при старте; непустое значение здесь перекрывает
# значения по умолчанию из аргументов CLI (если переменная задана).

# --- Первый проект Selectel (config.json → selectel.api) ---
SEL_USERNAME=
SEL_PASSWORD=
SEL_ACCOUNT_ID=
SEL_PROJECT_NAME=
SEL_PROJECT_ID=
SEL_SERVER_ID_RU2=
SEL_SERVER_ID_RU3=

# --- Второй проект (additional_accounts[0]) ---
SEL2_USERNAME=
SEL2_PASSWORD=
SEL2_ACCOUNT_ID=
SEL2_PROJECT_NAME=
SEL2_PROJECT_ID=
# Два UUID серверов через запятую
SEL2_SERVER_IDS=

# --- Регионы (опционально) ---
# Список через запятую, напр. ru-1,ru-2,ru-3. Пусто — из config / каталога API.
# SEL_SCANNER_REGIONS=

# ========== Скорость перебора IP и тайминги (на один процесс / аккаунт) ==========
# Главный рычаг нагрузки: сколько floating IP можно выдать за скользящие 60 с на аккаунт.
# 0 = лимит отключён. Пример: 30 → в среднем не чаще чем раз в 2 с на один IP (60/30).
# SEL_MAX_IPS_PER_MINUTE=30

# Сколько целевых совпадений по whitelist искать (остановка после достижения).
# SEL_TARGET_COUNT=1

# Размер батча выдачи: минимум и максимум за один запрос к API (часто 1 и 1).
# SEL_BATCH_SIZE=1
# SEL_MAX_BATCH_SIZE=1

# Параллельные DELETE несовпавших IP (не раздуливать при лимитах API).
# SEL_DELETE_CONCURRENCY=8

# Пауза стратегии при пустом ответе API, «тяжёлых» дубликатах и накопление backoff (сек).
# SEL_COOLDOWN_BASE=1.2
# SEL_COOLDOWN_MAX=15

# Как часто фоново сверять «лишние» floating IP (сек). Больше — реже фоновая нагрузка.
# SEL_RECONCILE_INTERVAL=7

# После create: сколько раз опросить список floating IP и пауза между опросами (сек).
# SEL_ALLOCATION_POLL_ATTEMPTS=5
# SEL_ALLOCATION_POLL_DELAY=0.45

# Частота обновления Rich-дашборда (Гц). На UI, не на API.
# SEL_REFRESH_PER_SECOND=6
