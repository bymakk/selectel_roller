# ======================================================================
#  ip-roller — МИНИМАЛЬНАЯ настройка
# ----------------------------------------------------------------------
#  В 99% случаев НИЧЕГО здесь руками заполнять НЕ нужно.
#  Просто запустите `./run.sh` (mac/linux) или `run.bat` (windows) —
#  программа сама спросит у вас логин/пароль/ID аккаунта и сохранит их
#  в реальный файл `.env` в этой папке.
#
#  Этот файл — только шаблон-справка, он попадает в git.
#  Настоящий `.env` программа создаст рядом и в git он не попадёт.
# ======================================================================

# --- Первый аккаунт Selectel (обязательно) ---
# Где взять:
#   SEL_USERNAME / SEL_PASSWORD — Панель Selectel → IAM → Сервисные
#                                 пользователи (создайте и сразу скопируйте пароль).
#   SEL_ACCOUNT_ID             — Правый верхний угол панели, под email'ом.
SEL_USERNAME=
SEL_PASSWORD=
SEL_ACCOUNT_ID=

# --- Первый аккаунт (опционально) ---
# Если НИЧЕГО из этого не задано, программа ВСЕГДА использует отдельный
# проект с именем `ip-roller`:
#   — если его ещё нет, создаст (не трогая ваши другие проекты);
#   — если уже есть, возьмёт именно его.
# Указывайте ниже только если хотите работать в другом, уже существующем проекте.
# SEL_PROJECT_NAME=
# SEL_PROJECT_ID=        # заполнится автоматически после первого запуска

# --- Второй аккаунт (опционально) ---
# Пустые SEL2_* = работаем только с первым аккаунтом.
# SEL2_USERNAME=
# SEL2_PASSWORD=
# SEL2_ACCOUNT_ID=
# SEL2_PROJECT_NAME=
# SEL2_PROJECT_ID=       # заполнится автоматически после первого запуска

# --- Регионы (опционально) ---
# Если не задано — сканер возьмёт ВСЕ регионы, доступные проекту.
# Для двух аккаунтов можно задать свои регионы на каждый воркер:
# SEL1_SCANNER_REGIONS=ru-1,ru-2,ru-3
# SEL2_SCANNER_REGIONS=ru-1,ru-2,ru-3

# ========== Скорость перебора IP и тайминги (опционально) ==========
# По умолчанию уже подобраны безопасные значения (~30 floating IP/мин).
# Трогайте, только если точно знаете, что делаете.
# SEL_MAX_IPS_PER_MINUTE=30
# SEL_TARGET_COUNT=1
# SEL_BATCH_SIZE=1
# SEL_MAX_BATCH_SIZE=1
# SEL_DELETE_CONCURRENCY=8
# SEL_COOLDOWN_BASE=1.2
# SEL_COOLDOWN_MAX=15
# SEL_RECONCILE_INTERVAL=7
# SEL_ALLOCATION_POLL_ATTEMPTS=5
# SEL_ALLOCATION_POLL_DELAY=0.45
# SEL_REFRESH_PER_SECOND=6
